# AWS
AWS_PROFILE=omaha-oracle
AWS_REGION=us-east-1

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Alpaca (paper trading)
ALPACA_API_KEY=xxxxx
ALPACA_SECRET_KEY=xxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# FRED
FRED_API_KEY=xxxxx

# SEC EDGAR — required; must be a real contact email per SEC fair-use policy
# Format: "AppName YourName your@email.com"
SEC_USER_AGENT=OmahaOracle YourName your@email.com

# Alerts / SNS
ALERT_EMAIL=your@email.com
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:omaha-oracle-dev-alerts

# Configuration
ENVIRONMENT=dev
LOG_LEVEL=INFO
MONTHLY_LLM_BUDGET_USD=50.0
